<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }} | BharatLike</title>
  <meta name="description" content="{{ description or 'BharatLike Blog – Social Media Growth Tips & Guides for India' }}" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.bharatlike.com{{ page.url }}" />
  <meta property="og:site_name" content="BharatLike" />
  <link rel="canonical" href="https://www.bharatlike.com{{ page.url }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
  <link rel="stylesheet" href="/styles.css?v=2" />
  <style>a.logo,a.logo:hover,a.logo:visited,a.logo:focus,a.logo:active{text-decoration:none!important;-webkit-text-decoration:none!important;border-bottom:none!important;box-shadow:none!important;}</style>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Idiqlat:wght@200;300;400&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Idiqlat:wght@200;300;400&display=swap" /></noscript>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" /></noscript>
</head>
<body>

  <header>
    <div class="container">
      <a href="/" class="logo">BharatLike</a>
      <button class="hamburger" id="hamburger" aria-label="Toggle navigation" onclick="toggleNav()">
        <span></span><span></span><span></span>
      </button>
      <nav id="main-nav">
        <a href="/">Home</a>
        <a href="/products/">Services</a>
        <a href="/products/pricing/">Pricing</a>
        <a href="/blog/" class="active">Blog</a>
        <a href="/aboutus/">About</a>
        <a href="/contactus/">Contact</a>
        <a href="#" id="darkToggle" onclick="toggleDark()">🌙</a>
      </nav>
    </div>
  </header>

  <main id="main-content">
    {{ content | safe }}
  </main>

  <footer>
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3>BharatLike</h3>
          <p>Your trusted partner in social media growth</p>
        </div>
        <div class="footer-section">
          <h3>Quick Links</h3>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/products/">Services</a></li>
            <li><a href="/products/pricing/">Pricing</a></li>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="/aboutus/">About</a></li>
            <li><a href="/contactus/">Contact</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h3>Contact</h3>
          <p>Durga Park Colony, Dashrath Puri<br />New Delhi, Delhi 110045<br />+91 9606380060</p>
        </div>
        <div class="footer-section">
          <h3>Follow Us</h3>
          <div class="social-links">
            <a href="https://www.facebook.com/61585822850890/" target="_blank" rel="noopener"><i class="fa-brands fa-facebook"></i> Facebook</a>
            <a href="https://www.instagram.com/bharatlikes_team/" target="_blank" rel="noopener"><i class="fa-brands fa-instagram"></i> Instagram</a>
            <a href="#"><i class="fa-brands fa-x-twitter"></i> Twitter</a>
          </div>
        </div>
        <div class="footer-section">
          <h3>Legal</h3>
          <ul>
            <li><a href="/privacy-policy/">Privacy Policy</a></li>
            <li><a href="/terms-of-service/">Terms of Service</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 BharatLike. All rights reserved. · <a href="/privacy-policy/">Privacy Policy</a> · <a href="/terms-of-service/">Terms of Service</a></p>
      </div>
    </div>
  </footer>

      <!-- WhatsApp Chat Widget -->
    <div class="wa-widget" id="waWidget">
      <div class="wa-popup" id="waPopup">
        <div class="wa-popup-header">
          <div class="wa-avatar">
            <i class="fa-brands fa-whatsapp"></i>
            <span class="wa-online-dot"></span>
          </div>
          <div class="wa-header-info">
            <div class="wa-header-name">BharatLike Support</div>
            <div class="wa-header-status">🟢 Typically replies instantly</div>
          </div>
          <button class="wa-close-btn" onclick="toggleWaWidget()" aria-label="Close">✕</button>
        </div>
        <div class="wa-popup-body">
          <div class="wa-message-bubble">
            👋 Hi there! Welcome to BharatLike.<br><br>
            How can we help you grow your social media today?
            <div class="wa-message-time">Today</div>
          </div>
        </div>
        <div class="wa-popup-footer">
          <a href="https://wa.me/919606380060?text=Hi%2C+came+across+your+website.+Would+like+to+know+more+about+the+services+and+the+pricing." class="wa-start-btn" target="_blank" rel="noopener" onclick="toggleWaWidget()">
            <i class="fa-brands fa-whatsapp"></i> Start Chat
          </a>
        </div>
      </div>
      <button class="wa-trigger" id="waTrigger" onclick="toggleWaWidget()" aria-label="Chat on WhatsApp">
        <i class="fa-brands fa-whatsapp"></i>
        <span class="wa-badge">1</span>
      </button>
    </div>
    <script>
      function toggleWaWidget() {
        var popup = document.getElementById("waPopup");
        var trigger = document.getElementById("waTrigger");
        var badge = trigger.querySelector(".wa-badge");
        popup.classList.toggle("open");
        trigger.classList.toggle("active");
        if (badge) badge.style.display = "none";
      }
      setTimeout(function() {
        var popup = document.getElementById("waPopup");
        if (!sessionStorage.getItem("waOpened")) {
          popup.classList.add("open");
          document.getElementById("waTrigger").classList.add("active");
          sessionStorage.setItem("waOpened", "1");
        }
      }, 4000);
    </script>

  <script src="/script.js" defer></script>
  <script>
    function toggleDark() {
      const isDark = document.body.classList.toggle('dark');
      localStorage.setItem('darkMode', isDark);
      const btn = document.getElementById('darkToggle');
      if (btn) btn.textContent = isDark ? '☀️' : '🌙';
    }
    window.addEventListener('DOMContentLoaded', () => {
      if (localStorage.getItem('darkMode') === 'true') {
        document.body.classList.add('dark');
        const btn = document.getElementById('darkToggle');
        if (btn) btn.textContent = '☀️';
      }
    });
  </script>

</body>
</html>
