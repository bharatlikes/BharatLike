    <script src="/script.js" defer></script>
    <script>
      // ── Cart Persistence (localStorage, 24-hour expiry from last access) ──
      const CART_KEY = 'bharatlike_cart';
      const ACCESS_KEY = 'bharatlike_last_access';
      const TTL_MS = 24 * 60 * 60 * 1000;

      function saveCart() {
        const cart = {};
        document.querySelectorAll('.price-row').forEach((row, i) => {
          const val = row.querySelector('.qty-input').value;
          if (parseInt(val) > 0) cart[i] = val;
        });
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
        localStorage.setItem(ACCESS_KEY, Date.now().toString());
      }

      function restoreCart() {
        const lastAccess = parseInt(localStorage.getItem(ACCESS_KEY) || '0');
        if (Date.now() - lastAccess > TTL_MS) {
          localStorage.removeItem(CART_KEY);
          localStorage.removeItem(ACCESS_KEY);
          return;
        }
        const cart = JSON.parse(localStorage.getItem(CART_KEY) || '{}');
        const rows = document.querySelectorAll('.price-row');
        Object.entries(cart).forEach(([i, val]) => {
          if (rows[i]) {
            rows[i].querySelector('.qty-input').value = val;
            updateTotal(rows[i].querySelector('.qty-input'));
          }
        });
        localStorage.setItem(ACCESS_KEY, Date.now().toString());
      }

      function clearCart() {
        if (!confirm('Clear all saved quantities?')) return;
        localStorage.removeItem(CART_KEY);
        localStorage.removeItem(ACCESS_KEY);
        document.querySelectorAll('.qty-input').forEach((input) => {
          input.value = 0;
          updateTotal(input);
        });
      }

      document.addEventListener('DOMContentLoaded', () => {
        restoreCart();
        // Handle URL hash to auto-open a platform panel
        // Supports both #panel-instagram and #instagram formats
        let hash = window.location.hash.replace('#', '').replace('panel-', '');
        const validPlatforms = ['instagram', 'facebook', 'youtube', 'twitter'];
        if (validPlatforms.includes(hash)) {
          const btn = document.getElementById('btn-' + hash);
          if (btn) openPlatform(hash, btn);
        }
      });

      // ── Platform panel toggle ──
      function openPlatform(platform, btn) {
        const allPanels = document.querySelectorAll('.platform-panel');
        const allBtns = document.querySelectorAll('.platform-btn');
        const target = document.getElementById('panel-' + platform);
        const isOpen = target.classList.contains('open');

        allPanels.forEach((p) => p.classList.remove('open'));
        allBtns.forEach((b) => b.classList.remove('active'));

        if (!isOpen) {
          target.classList.add('open');
          btn.classList.add('active');
          setTimeout(
            () =>
              target.scrollIntoView({ behavior: 'smooth', block: 'nearest' }),
            50
          );
        }
      }

      // ── Service sub-tab toggle ──
      function openService(platform, service, tab) {
        const platformMap = {
          ig: 'instagram',
          fb: 'facebook',
          yt: 'youtube',
          tw: 'twitter',
        };
        const panel = document.getElementById(
          'panel-' + (platformMap[platform] || platform)
        );
        panel
          .querySelectorAll('.service-content > div')
          .forEach((d) => (d.style.display = 'none'));
        panel
          .querySelectorAll('.service-tab')
          .forEach((t) => t.classList.remove('active'));
        document.getElementById(platform + '-' + service).style.display =
          'block';
        tab.classList.add('active');
      }

      const platformNames = {
        'panel-instagram': '📸 Instagram',
        'panel-facebook': '📘 Facebook',
        'panel-youtube': '▶️ YouTube',
        'panel-twitter': '🐦 Twitter / X',
      };

      function getServiceLabel(row) {
        const subDiv = row.closest('[id]');
        const labels = {
          'ig-views': 'Views',
          'ig-likes': 'Likes',
          'ig-followers': 'Followers (Indian)',
          'fb-likes': 'Likes',
          'fb-comments': 'Comments',
          'fb-views': 'Views',
          'fb-pagelikes': 'Page Likes',
          'yt-views': 'Views',
          'yt-subscribers': 'Subscribers',
          'yt-likes': 'Likes',
          'tw-followers': 'Followers',
          'tw-comments': 'Comments',
          'tw-favorites': 'Favorites',
        };
        return labels[subDiv?.id] || subDiv?.id || '';
      }

      function updateTotal(input) {
        const row = input.closest('tr');
        const unit = parseFloat(row.dataset.unit) || 0;
        const qty = parseInt(input.value) || 0;
        row.querySelector('.total-price').textContent =
          '₹' + (unit * qty).toLocaleString('en-IN');
        recalcGrandTotal();
        saveCart();
      }

      function recalcGrandTotal() {
        let grand = 0;
        document.querySelectorAll('.price-row').forEach((r) => {
          const u = parseFloat(r.dataset.unit) || 0;
          const q = parseInt(r.querySelector('.qty-input').value) || 0;
          grand += u * q;
        });
        document.getElementById('ugt-amount').textContent =
          '₹' + grand.toLocaleString('en-IN');
        const note = document.getElementById('ugt-note');
        note.textContent =
          grand > 0
            ? 'across all platforms & packages'
            : 'Add quantities above to see your total';
      }

      function placeOrder() {
        const platforms = [
          'panel-instagram',
          'panel-facebook',
          'panel-youtube',
          'panel-twitter',
        ];
        let lines = [],
          grandTotal = 0,
          hasItems = false;

        platforms.forEach((panelId) => {
          const panel = document.getElementById(panelId);
          if (!panel) return;
          let platformLines = [];
          panel.querySelectorAll('.price-row').forEach((row) => {
            const qty = parseInt(row.querySelector('.qty-input').value) || 0;
            if (qty === 0) return;
            hasItems = true;
            const unit = parseFloat(row.dataset.unit) || 0;
            const total = unit * qty;
            const pkg = row.querySelector('.qty-label').textContent.trim();
            const service = getServiceLabel(row);
            grandTotal += total;
            platformLines.push(
              `  • ${service} – ${pkg} × ${qty} packet(s) @ ₹${unit.toLocaleString('en-IN')} = ₹${total.toLocaleString('en-IN')}`
            );
          });
          if (platformLines.length > 0) {
            lines.push(platformNames[panelId]);
            lines = lines.concat(platformLines);
            lines.push('');
          }
        });

        if (!hasItems) {
          alert('Please add at least one item before placing an order.');
          return;
        }

        const invoice = [
          'Hey BharatLike Team! I would like to place an order with the following details:',
          '🛒 *Order Details —*',
          '━━━━━━━━━━━━━━━━━━━━━━━━━',
          '',
          ...lines,
          '━━━━━━━━━━━━━━━━━━━━━━━━━',
          `💰 *Grand Total: ₹${grandTotal.toLocaleString('en-IN')}*`,
          '',
          'Please confirm availability and payment details. Thank you!',
        ].join('\n');

        window.open(
          'https://wa.me/919606380060?text=' + encodeURIComponent(invoice),
          '_blank'
        );
      }
    </script>
